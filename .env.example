# Copy to `.env` and fill in. `.env` is gitignored — never commit tokens or paste them in source code.

# Developer Portal → General Information → Application ID (public; used for invite URL in logs)
DISCORD_APPLICATION_ID=

# Required — Developer Portal → Bot → token (use env var TOKEN only; do not hardcode in .py files)
TOKEN=

# Pick ONE delivery target:

# Option A — DM you: your USER id (right-click your avatar), not the Application ID.
DISCORD_DM_USER_ID=

# Option B — post in a server channel instead (leave DISCORD_DM_USER_ID empty)
# DISCORD_CHANNEL_ID=

# Optional — Server ID (Developer Mode → right-click server icon → Copy Server ID).
# Slash commands register to this guild immediately; omit for global sync (~up to 1h).
# DISCORD_GUILD_ID=
